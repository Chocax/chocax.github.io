       <span style="color: #c678dd;">END AS</span> exclusion_reason,
       <span style="color: #c678dd;">CASE</span> 
           <span style="color: #c678dd;">WHEN</span> years_service >= min_years_service <span style="color: #c678dd;">AND</span> salary < max_allowed_salary 
           <span style="color: #c678dd;">THEN</span> <span style="color: #98c379;">'ELEGIBLE'</span> <span style="color: #c678dd;">ELSE</span> <span style="color: #98c379;">'NO_ELEGIBLE'</span>
       <span style="color: #c678dd;">END AS</span> eligibility_flag
<span style="color: #c678dd;">FROM</span> base_data;`
  },

  {
    id: "20",
    titulo: "Actualización Masiva: MERGE con Escudo de Integridad",
    enunciado: "Implementación de una sentencia MERGE compleja para la actualización de salarios. El script integra la lógica de elegibilidad analizada previamente para ejecutar incrementos automáticos. Incluye una cláusula de salvaguarda (escudo) que garantiza que el proceso solo realice modificaciones si el resultado es un aumento, protegiendo los salarios base actuales contra desajustes de cálculo.",
    archivo: "ejercicio_20.sql",
    codigo: `<span style="color: #5c6370;">/* AUTORES: SANTIAGO PINZÓN VÁSQUEZ - JAIBER DIAZ
FECHA: 08/04/2026
DESCRIPCIÓN: Sentencia MERGE avanzada para actualización masiva de salarios con filtros de elegibilidad.
*/</span>
<span style="color: #c678dd;">MERGE INTO</span> t1_employees target
<span style="color: #c678dd;">USING</span> (
    <span style="color: #c678dd;">WITH</span> v_var <span style="color: #c678dd;">AS</span> ( <span style="color: #c678dd;">SELECT</span> * <span style="color: #c678dd;">FROM</span> t1_variants <span style="color: #c678dd;">WHERE</span> variant_id = &p_variant_id ),
    dept_stats <span style="color: #c678dd;">AS</span> ( <span style="color: #c678dd;">SELECT</span> department_id, <span style="color: #e5c07b;">ROUND</span>(<span style="color: #e5c07b;">AVG</span>(salary), 2) <span style="color: #c678dd;">AS</span> dept_avg_salary <span style="color: #c678dd;">FROM</span> t1_employees <span style="color: #c678dd;">GROUP BY</span> department_id ),
    base_data <span style="color: #c678dd;">AS</span> (
        <span style="color: #c678dd;">SELECT</span> e.employee_id, e.department_id, e.salary, ds.dept_avg_salary,
               <span style="color: #c678dd;">CASE WHEN</span> e.salary < ds.dept_avg_salary <span style="color: #c678dd;">THEN</span> <span style="color: #e5c07b;">ROUND</span>(((ds.dept_avg_salary - e.salary) / ds.dept_avg_salary) * 100, 2) <span style="color: #c678dd;">ELSE</span> 0 <span style="color: #c678dd;">END AS</span> pct_gap_to_avg,
               v.* <span style="color: #c678dd;">FROM</span> t1_employees e 
        <span style="color: #c678dd;">LEFT JOIN</span> dept_stats ds <span style="color: #c678dd;">ON</span> e.department_id = ds.department_id 
        <span style="color: #c678dd;">CROSS JOIN</span> v_var v
    )
    <span style="color: #c678dd;">SELECT</span> employee_id, 
           <span style="color: #e5c07b;">LEAST</span>(
             <span style="color: #e5c07b;">ROUND</span>(salary * (1 + (<span style="color: #c678dd;">CASE WHEN</span> pct_gap_to_avg >= gap_high_threshold_pct <span style="color: #c678dd;">THEN</span> raise_high_pct <span style="color: #c678dd;">ELSE</span> raise_low_pct <span style="color: #c678dd;">END</span>) / 100), 2), 
             <span style="color: #e5c07b;">ROUND</span>(dept_avg_salary * (max_salary_vs_avg_pct / 100), 2)
           ) <span style="color: #c678dd;">AS</span> salary_after
    <span style="color: #c678dd;">FROM</span> base_data 
    <span style="color: #c678dd;">WHERE</span> department_id <span style="color: #c678dd;">IS NOT NULL AND</span> years_service >= min_years_service
) source
<span style="color: #c678dd;">ON</span> (target.employee_id = source.employee_id)
<span style="color: #c678dd;">WHEN MATCHED THEN</span> 
    <span style="color: #c678dd;">UPDATE SET</span> target.salary = source.salary_after
    <span style="color: #c678dd;">WHERE</span> source.salary_after > target.salary;`
  }

  
];
