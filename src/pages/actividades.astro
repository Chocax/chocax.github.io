{
    id: "07",
    titulo: "Stored Procedure: Saludo y Lógica de Fechas",
    enunciado: "Creación de un procedimiento almacenado en PL/SQL que demuestra el uso de parámetros opcionales con valores por defecto, concatenación de cadenas y la identificación dinámica del último viernes de un mes específico.",
    archivo: "ejercicio_07.sql",
    codigo: `<span style="color: #5c6370;">/* AUTOR: SANTIAGO PINZÓN VÁSQUEZ
FECHA: 23/02/2026
DESCRIPCIÓN: Procedimiento almacenado que gestiona parámetros IN y realiza cálculos temporales avanzados con NEXT_DAY y LAST_DAY.
*/</span>
<span style="color: #c678dd;">CREATE OR REPLACE PROCEDURE</span> sp_saludar (
    param_nombre <span style="color: #c678dd;">IN</span> <span style="color: #e5c07b;">VARCHAR2</span> <span style="color: #c678dd;">DEFAULT</span> <span style="color: #98c379;">'Millos'</span>,
    param_fecha  <span style="color: #c678dd;">IN</span> <span style="color: #e5c07b;">DATE</span>     <span style="color: #c678dd;">DEFAULT</span> <span style="color: #c678dd;">SYSDATE</span>
)
<span style="color: #c678dd;">IS</span>
    vv_textoConcatenado <span style="color: #e5c07b;">VARCHAR2</span>(100);
    vd_ultimoViernes    <span style="color: #e5c07b;">DATE</span>;
<span style="color: #c678dd;">BEGIN</span>
    vv_textoConcatenado := <span style="color: #98c379;">'Hola, '</span> || param_nombre || <span style="color: #98c379;">' tu papá '</span>;
    <span style="color: #e5c07b;">dbms_output.put_line</span>(vv_textoConcatenado);
     
    vd_ultimoViernes := <span style="color: #e5c07b;">NEXT_DAY</span>(<span style="color: #e5c07b;">LAST_DAY</span>(param_fecha) - 7, <span style="color: #98c379;">'VIERNES'</span>);
    <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'El ultimo viernes es '</span> || vd_ultimoViernes);
<span style="color: #c678dd;">END</span> sp_saludar;
/

<span style="color: #5c6370;">-- Llamada al procedimiento</span>
<span style="color: #c678dd;">BEGIN</span>
    sp_saludar();
<span style="color: #c678dd;">END</span>;
/`
  },
{
    id: "08",
    titulo: "Cursor Dinámico: Empleados por Departamento",
    enunciado: "Implementación de un bloque PL/SQL que utiliza un cursor explícito y una variable de sustitución (&) para filtrar y listar los empleados pertenecientes a un ID de departamento ingresado por consola.",
    archivo: "ejercicio_08.sql",
    codigo: `<span style="color: #5c6370;">/* AUTOR: SANTIAGO PINZÓN VÁSQUEZ
FECHA: 02/03/2026
DESCRIPCIÓN: Cursor dinámico que filtra empleados por ID de departamento usando variables de sustitución.
*/</span>
<span style="color: #c678dd;">DECLARE</span>
    v_target_dept <span style="color: #e5c07b;">NUMBER</span> := &DIGITE_ID_DEPARTAMENTO;

    <span style="color: #c678dd;">CURSOR</span> c_empleados <span style="color: #c678dd;">IS</span>
      <span style="color: #c678dd;">SELECT</span> employee_id, first_name, last_name, department_id
      <span style="color: #c678dd;">FROM</span> EMPLOYEES
      <span style="color: #c678dd;">WHERE</span> department_id = v_target_dept;

    v_emp c_empleados<span style="color: #e5c07b;">%ROWTYPE</span>;
    v_contador <span style="color: #e5c07b;">NUMBER</span> := 0;
<span style="color: #c678dd;">BEGIN</span>
    <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'--- LISTADO PARA EL DEPARTAMENTO: '</span> || v_target_dept || <span style="color: #98c379;">' ---'</span>);

    <span style="color: #c678dd;">OPEN</span> c_empleados;
    <span style="color: #c678dd;">LOOP</span>
        <span style="color: #c678dd;">FETCH</span> c_empleados <span style="color: #c678dd;">INTO</span> v_emp;
        <span style="color: #c678dd;">EXIT WHEN</span> c_empleados<span style="color: #e5c07b;">%NOTFOUND</span>;
        
        v_contador := v_contador + 1;
        <span style="color: #e5c07b;">dbms_output.put_line</span>(
            v_emp.employee_id || <span style="color: #98c379;">' - '</span> ||
            v_emp.first_name || <span style="color: #98c379;">' '</span> ||
            v_emp.last_name ||
            <span style="color: #98c379;">' (Depto: '</span> || v_emp.department_id || <span style="color: #98c379;">')'</span>
        );
    <span style="color: #c678dd;">END LOOP</span>;
    
    <span style="color: #c678dd;">IF</span> v_contador = 0 <span style="color: #c678dd;">THEN</span>
        <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'No se encontró a nadie en el ID: '</span> || v_target_dept);
    <span style="color: #c678dd;">ELSE</span>
        <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'Total de empleados: '</span> || v_contador);
    <span style="color: #c678dd;">END IF</span>;

    <span style="color: #c678dd;">CLOSE</span> c_empleados;
<span style="color: #c678dd;">END</span>;
/`
  },

  {
    id: "09",
    titulo: "Reporte de Nómina Mensual",
    enunciado: "Generación de un reporte detallado de nómina mediante el uso de cursores con ciclos FOR. El script permite filtrar por mes y año a través de variables de sustitución, formateando la salida en consola con funciones de alineación para presentar una estructura de tabla.",
    archivo: "ejercicio_09.sql",
    codigo: `<span style="color: #5c6370;">/* AUTOR: SANTIAGO PINZÓN VÁSQUEZ
FECHA: 02/03/2026
DESCRIPCIÓN: Reporte de nómina detallado con formato de tabla, manejo de joins y variables de sustitución.
*/</span>
<span style="color: #c678dd;">DECLARE</span>
    <span style="color: #5c6370;">-- Capturamos mes y año con el "scanner" (&)</span>
    v_mes  <span style="color: #e5c07b;">VARCHAR2</span>(2) := <span style="color: #98c379;">'&MM_EJ_02'</span>;
    v_anio <span style="color: #e5c07b;">VARCHAR2</span>(4) := <span style="color: #98c379;">'&YYYY_EJ_2026'</span>;
    
    <span style="color: #c678dd;">CURSOR</span> c_nomina <span style="color: #c678dd;">IS</span>
        <span style="color: #c678dd;">SELECT</span> 
            p.employee_id,
            e.first_name || <span style="color: #98c379;">' '</span> || e.last_name <span style="color: #c678dd;">as</span> nombre_completo,
            p.gross_total,
            p.ded_total,
            p.net_total,
            p.status
        <span style="color: #c678dd;">FROM</span> pay_payslips p
        <span style="color: #c678dd;">JOIN</span> employees e <span style="color: #c678dd;">ON</span> p.employee_id = e.employee_id
        <span style="color: #c678dd;">WHERE</span> <span style="color: #e5c07b;">TO_CHAR</span>(p.calc_date, <span style="color: #98c379;">'MM'</span>) = v_mes
          <span style="color: #c678dd;">AND</span> <span style="color: #e5c07b;">TO_CHAR</span>(p.calc_date, <span style="color: #98c379;">'YYYY'</span>) = v_anio;

    v_total_nomina <span style="color: #e5c07b;">NUMBER</span> := 0;
    v_conteo_emp   <span style="color: #e5c07b;">NUMBER</span> := 0;
<span style="color: #c678dd;">BEGIN</span>
    <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'================================================================'</span>);
    <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'REPORTE DE NÓMINA: '</span> || v_mes || <span style="color: #98c379;">'/'</span> || v_anio);
    <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'================================================================'</span>);
    <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'ID EMP  | NOMBRE               | BRUTO      | DEDUC.    | NETO'</span>);
    <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'----------------------------------------------------------------'</span>);

    <span style="color: #5c6370;">-- Recorremos con un FOR para que sea más eficiente (apertura y cierre automático)</span>
    <span style="color: #c678dd;">FOR</span> r_nom <span style="color: #c678dd;">IN</span> c_nomina <span style="color: #c678dd;">LOOP</span>
        v_conteo_emp := v_conteo_emp + 1;
        v_total_nomina := v_total_nomina + r_nom.net_total;
        
        <span style="color: #e5c07b;">dbms_output.put_line</span>(
            <span style="color: #e5c07b;">RPAD</span>(r_nom.employee_id, 8) || <span style="color: #98c379;">' | '</span> ||
            <span style="color: #e5c07b;">RPAD</span>(<span style="color: #e5c07b;">SUBSTR</span>(r_nom.nombre_completo, 1, 20), 20) || <span style="color: #98c379;">' | '</span> ||
            <span style="color: #e5c07b;">LPAD</span>(<span style="color: #e5c07b;">TO_CHAR</span>(r_nom.gross_total, <span style="color: #98c379;">'999,999,999'</span>), 10) || <span style="color: #98c379;">' | '</span> ||
            <span style="color: #e5c07b;">LPAD</span>(<span style="color: #e5c07b;">TO_CHAR</span>(r_nom.ded_total, <span style="color: #98c379;">'999,999,999'</span>), 9) || <span style="color: #98c379;">' | '</span> ||
            <span style="color: #e5c07b;">LPAD</span>(<span style="color: #e5c07b;">TO_CHAR</span>(r_nom.net_total, <span style="color: #98c379;">'999,999,999'</span>), 10)
        );
    <span style="color: #c678dd;">END LOOP</span>;

    <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'----------------------------------------------------------------'</span>);
    
    <span style="color: #c678dd;">IF</span> v_conteo_emp = 0 <span style="color: #c678dd;">THEN</span>
        <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'AVISO: No se encontraron registros para ese periodo.'</span>);
    <span style="color: #c678dd;">ELSE</span>
        <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'Resumen:'</span>);
        <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'Total Empleados Pagados: '</span> || v_conteo_emp);
        <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'Costo Total Nómina (Neto): $'</span> || <span style="color: #e5c07b;">TO_CHAR</span>(v_total_nomina, <span style="color: #98c379;">'999,999,999,999'</span>));
    <span style="color: #c678dd;">END IF</span>;
    
    <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'================================================================'</span>);
<span style="color: #c678dd;">END</span>;
/`
  },

  {
    id: "10",
    titulo: "Función: Cálculo de Integral Definida",
    enunciado: "Implementación de una función almacenada (Stored Function) para calcular la integral definida de la potencia x^n en un intervalo [a, b], aplicando la regla fundamental del cálculo para potencias.",
    archivo: "ejercicio_10.sql",
    codigo: `<span style="color: #5c6370;">/* AUTOR: SANTIAGO PINZÓN VÁSQUEZ
FECHA: 04/03/2026
DESCRIPCIÓN: Función que calcula la integral definida de x^n en el intervalo [a, b].
*/</span>
<span style="color: #c678dd;">CREATE OR REPLACE FUNCTION</span> fn_integral_basica (
    vn_a <span style="color: #c678dd;">IN</span> <span style="color: #e5c07b;">NUMBER</span>, 
    vn_b <span style="color: #c678dd;">IN</span> <span style="color: #e5c07b;">NUMBER</span>, 
    vn_n <span style="color: #c678dd;">IN</span> <span style="color: #e5c07b;">NUMBER</span>
) 
<span style="color: #c678dd;">RETURN</span> <span style="color: #e5c07b;">NUMBER</span> 
<span style="color: #c678dd;">IS</span>
    vn_resultado <span style="color: #e5c07b;">NUMBER</span>;
<span style="color: #c678dd;">BEGIN</span>
    <span style="color: #5c6370;">-- Aplicación de la fórmula: (b^(n+1) / (n+1)) - (a^(n+1) / (n+1))</span>
    vn_resultado := (<span style="color: #e5c07b;">POWER</span>(vn_b, vn_n + 1) / (vn_n + 1)) - (<span style="color: #e5c07b;">POWER</span>(vn_a, vn_n + 1) / (vn_n + 1));
    <span style="color: #c678dd;">RETURN</span> vn_resultado;
<span style="color: #c678dd;">END</span>;
/`
  },

  {
    id: "11",
    titulo: "Función: Cálculo de Edad Precisa",
    enunciado: "Desarrollo de una función almacenada que recibe una fecha de nacimiento y retorna la edad exacta en años, utilizando MONTHS_BETWEEN para garantizar precisión independientemente de los años bisiestos.",
    archivo: "ejercicio_11.sql",
    codigo: `<span style="color: #5c6370;">/* AUTOR: SANTIAGO PINZÓN VÁSQUEZ
FECHA: 04/03/2026
DESCRIPCIÓN: Función que calcula la edad actual a partir de una fecha dada.
*/</span>
<span style="color: #c678dd;">CREATE OR REPLACE FUNCTION</span> fn_calcular_edad (
    pd_fecha_nac <span style="color: #c678dd;">IN</span> <span style="color: #e5c07b;">DATE</span>
) 
<span style="color: #c678dd;">RETURN</span> <span style="color: #e5c07b;">NUMBER</span> 
<span style="color: #c678dd;">IS</span>
    vn_edad <span style="color: #e5c07b;">NUMBER</span>;
<span style="color: #c678dd;">BEGIN</span>
    vn_edad := <span style="color: #e5c07b;">TRUNC</span>(<span style="color: #e5c07b;">MONTHS_BETWEEN</span>(<span style="color: #c678dd;">SYSDATE</span>, pd_fecha_nac) / 12);
    <span style="color: #c678dd;">RETURN</span> vn_edad;
