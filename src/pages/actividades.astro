),
base_data <span style="color: #c678dd;">AS</span> (
    <span style="color: #c678dd;">SELECT</span> e.employee_id, e.first_name, e.last_name, e.department_id, e.salary,
           <span style="color: #e5c07b;">TRUNC</span>(<span style="color: #e5c07b;">MONTHS_BETWEEN</span>(<span style="color: #c678dd;">SYSDATE</span>, e.hire_date) / 12) <span style="color: #c678dd;">AS</span> years_service,
           ds.dept_avg_salary, ds.dept_employee_count,
