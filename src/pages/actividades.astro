),
dept_stats <span style="color: #c678dd;">AS</span> (
    <span style="color: #c678dd;">SELECT</span> department_id,
           <span style="color: #e5c07b;">ROUND</span>(<span style="color: #e5c07b;">AVG</span>(salary), 2) <span style="color: #c678dd;">AS</span> dept_avg_salary,
           <span style="color: #e5c07b;">MAX</span>(salary) <span style="color: #c678dd;">AS</span> dept_max_salary,
           <span style="color: #e5c07b;">COUNT</span>(employee_id) <span style="color: #c678dd;">AS</span> dept_employee_count
    <span style="color: #c678dd;">FROM</span> t1_employees
    <span style="color: #c678dd;">GROUP BY</span> department_id
),
job_hist <span style="color: #c678dd;">AS</span> (
