<!DOCTYPE html>
<html lang="es">
  <Header title="Actividades | Santiago" />
  <body>
    <div class="content">
      <Sidebar selectedItem="actividades" />
      <nav class="main">
        <div class="container" style="max-width: 1200px; padding: 60px 40px;">
          
          <header style="margin-bottom: 40px; border-bottom: 1px solid #222; padding-bottom: 30px;">
            <h2 style="font-size: 3.5rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 20px;">
              Actividades Oracle SQL
            </h2>
            <div style="background: #1a1a1a; border-left: 4px solid #ffbd2e; padding: 15px 25px; border-radius: 4px;">
              <p style="color: #e0e0e0; font-size: 1.1rem; line-height: 1.6; margin: 0;">
                Ejercicios desarrollados durante la asignatura de <strong>Bases de Datos II</strong>. Retos de lógica y aplicaciones prácticas en el esquema <strong>HR</strong>.
              </p>
            </div>
          </header>

          <div class="pagination-wrapper top-pag">
            <div class="pagination-info">Mostrando página <span class="current-page-text">1</span> de <span class="total-pages-text">1</span></div>
            <div class="pagination-controls"></div>
          </div>

          <div id="exercises-container" class="activities-stack" style="display: flex; flex-direction: column; gap: 90px; margin: 40px 0;">
            {ejercicios.map((ej) => (
              <section class="activity-item">
                <div style="margin-bottom: 35px;"> 
                  <span style="color: #fff; background: #333; padding: 5px 15px; border-radius: 4px; font-family: monospace; font-size: 0.8rem;">EJERCICIO {ej.id}</span>
                  <h3 style="font-size: 2.2rem; margin: 20px 0; color: #fff;">{ej.titulo}</h3>
                  <p style="color: #bbb; font-size: 1.2rem; line-height: 1.8; margin-top: 15px;"> 
                    {ej.enunciado}
                    {ej.nota && <><br/><span style="color: #777; font-size: 1rem;">{ej.nota}</span></>}
                  </p>
                </div>

                <div class="code-terminal" style="width: 100%; background: #0d0d0d; border-radius: 12px; border: 1px solid #222; overflow: hidden; box-shadow: 0 30px 60px rgba(0,0,0,0.5);">
                  <div style="background: #1a1a1a; padding: 12px 20px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #222;">
                    <div style="display: flex; gap: 8px;">
                      <div style="width: 12px; height: 12px; border-radius: 50%; background: #ff5f56;"></div>
                      <div style="width: 12px; height: 12px; border-radius: 50%; background: #ffbd2e;"></div>
                      <div style="width: 12px; height: 12px; border-radius: 50%; background: #27c93f;"></div>
                    </div>
                    <span style="color: #555; font-family: monospace; font-size: 0.8rem;">{ej.archivo}</span>
                  </div>
                  <pre style="margin: 0; padding: 40px; overflow-x: auto; font-family: 'Fira Code', monospace; font-size: 1.1rem; line-height: 1.6;"><code style="color: #abb2bf;" set:html={ej.codigo}></code></pre>
                </div>
              </section>
            ))}
          </div>

          <div class="pagination-wrapper bottom-pag">
            <div class="pagination-controls"></div>
          </div>

        </div>
      </nav>
    </div>

    <style>
      .pagination-wrapper {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 0;
        border-top: 1px solid #222;
        border-bottom: 1px solid #222;
      }
      .bottom-pag { border-bottom: none; margin-top: 40px; justify-content: center; }
      
      .pagination-info { color: #555; font-size: 0.9rem; font-family: monospace; }
      
      .pagination-controls { display: flex; gap: 8px; }

      :global(.page-btn) {
        background: #0d0d0d;
        color: #888;
        border: 1px solid #222;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        cursor: pointer;
        font-family: 'Fira Code', monospace;
        font-size: 0.9rem;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      }

      :global(.page-btn:hover) {
        border-color: #ffbd2e;
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(255, 189, 46, 0.1);
      }

      :global(.page-btn.active) {
        background: #ffbd2e;
        color: #000;
        border-color: #ffbd2e;
        font-weight: 800;
        box-shadow: 0 0 20px rgba(255, 189, 46, 0.2);
      }
    </style>

    <script>
      const ITEMS_PER_PAGE = 5;
      const container = document.getElementById('exercises-container');
      const exercises = Array.from(container.getElementsByClassName('activity-item'));
      const controlContainers = document.querySelectorAll('.pagination-controls');
      const totalPages = Math.ceil(exercises.length / ITEMS_PER_PAGE);

      // Actualizar textos informativos
      document.querySelectorAll('.total-pages-text').forEach(el => el.innerText = totalPages.toString());

      function showPage(pageNumber) {
        const start = (pageNumber - 1) * ITEMS_PER_PAGE;
        const end = start + ITEMS_PER_PAGE;

        exercises.forEach((ex, index) => {
          (ex as HTMLElement).style.display = (index >= start && index < end) ? 'block' : 'none';
        });

        // Sincronizar botones activos en ambos controles
        document.querySelectorAll('.page-btn').forEach(btn => {
          btn.classList.toggle('active', parseInt((btn as HTMLElement).innerText) === pageNumber);
        });

        // Actualizar número de página actual
        document.querySelectorAll('.current-page-text').forEach(el => (el as HTMLElement).innerText = pageNumber.toString());

        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      // Generar botones en todos los contenedores de control
      controlContainers.forEach(nav => {
        for (let i = 1; i <= totalPages; i++) {
          const btn = document.createElement('button');
          btn.innerText = i.toString();
          btn.className = 'page-btn';
          btn.onclick = () => showPage(i);
          nav.appendChild(btn);
        }
      });

      showPage(1);
    </script>
  </body>
</html>