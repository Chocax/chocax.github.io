    <span style="color: #c678dd;">FROM</span> t1_job_history
    <span style="color: #c678dd;">GROUP BY</span> employee_id
)
<span style="color: #c678dd;">SELECT</span> e.employee_id,
       e.first_name,
       e.last_name,
       d.department_name,
       e.salary,
       <span style="color: #e5c07b;">TRUNC</span>(<span style="color: #e5c07b;">MONTHS_BETWEEN</span>(<span style="color: #c678dd;">SYSDATE</span>, e.hire_date) / 12) <span style="color: #c678dd;">AS</span> years_service,
       ds.dept_avg_salary,
       <span style="color: #c678dd;">CASE WHEN</span> e.salary < ds.dept_avg_salary 
            <span style="color: #c678dd;">THEN</span> <span style="color: #e5c07b;">ROUND</span>(((ds.dept_avg_salary - e.salary) / ds.dept_avg_salary) * 100, 2)
            <span style="color: #c678dd;">ELSE</span> 0 
       <span style="color: #c678dd;">END AS</span> pct_gap_to_avg,
       <span style="color: #e5c07b;">RANK</span>() <span style="color: #c678dd;">OVER</span> (<span style="color: #c678dd;">PARTITION BY</span> e.department_id <span style="color: #c678dd;">ORDER BY</span> e.salary <span style="color: #c678dd;">DESC</span>) <span style="color: #c678dd;">AS</span> salary_rank
<span style="color: #c678dd;">FROM</span> t1_employees e
<span style="color: #c678dd;">LEFT JOIN</span> t1_departments d <span style="color: #c678dd;">ON</span> e.department_id = d.department_id
<span style="color: #c678dd;">LEFT JOIN</span> dept_stats ds <span style="color: #c678dd;">ON</span> e.department_id = ds.department_id
<span style="color: #c678dd;">LEFT JOIN</span> job_hist jh <span style="color: #c678dd;">ON</span> e.employee_id = jh.employee_id
<span style="color: #c678dd;">ORDER BY</span> e.department_id, e.salary <span style="color: #c678dd;">DESC</span>;`
