           <span style="color: #c678dd;">CASE WHEN</span> jh.last_end_date <span style="color: #c678dd;">IS NOT NULL AND</span> <span style="color: #e5c07b;">MONTHS_BETWEEN</span>(<span style="color: #c678dd;">SYSDATE</span>, jh.last_end_date) <= v.recent_job_history_months <span style="color: #c678dd;">THEN</span> <span style="color: #98c379;">'SI'</span> <span style="color: #c678dd;">ELSE</span> <span style="color: #98c379;">'NO'</span> <span style="color: #c678dd;">END AS</span> recent_job_history_flag,
