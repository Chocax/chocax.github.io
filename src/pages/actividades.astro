---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";

// --- ÁREA DE DATOS: AQUÍ AGREGAS LOS EJERCICIOS NUEVOS ---
const ejercicios = [
  {
    id: "01",
    titulo: "Rotación de Cargos",
    enunciado: "¿Cuántos empleados han pasado por más de un cargo en la compañía?",
    archivo: "query_01.sql",
    codigo: `<span style="color: #c678dd;">SELECT</span> E.FIRST_NAME, H.EMPLOYEE_ID, <span style="color: #e5c07b;">COUNT</span>(*) <span style="color: #c678dd;">AS</span> job_count
<span style="color: #c678dd;">FROM</span> HR.JOB_HISTORY H <span style="color: #c678dd;">JOIN</span> HR.EMPLOYEES E
<span style="color: #c678dd;">ON</span> H.EMPLOYEE_ID = E.EMPLOYEE_ID
<span style="color: #c678dd;">GROUP BY</span> E.FIRST_NAME, H.EMPLOYEE_ID
<span style="color: #c678dd;">HAVING COUNT</span> (*) > 1;`
  },
  {
    id: "02",
    titulo: "Filtro de Empleados en Europa",
    enunciado: "Identifique todos los empleados que vivan o trabajen en europa y tengan un salario entre 4000 y 6000 dolares.",
    nota: "(Nombres y apellidos en una sola columna, pais, salario)",
    archivo: "query_02.sql",
    codigo: `<span style="color: #c678dd;">SELECT CONCAT</span> (E.FIRST_NAME, <span style="color: #98c379;">' '</span>, E.LAST_NAME) <span style="color: #c678dd;">AS</span> NAME, C.COUNTRY_NAME <span style="color: #c678dd;">AS</span> COUNTRY, E.SALARY
<span style="color: #c678dd;">FROM</span> HR.EMPLOYEES E <span style="color: #c678dd;">JOIN</span> HR.DEPARTMENTS D
<span style="color: #c678dd;">ON</span> E.DEPARTMENT_ID = D.DEPARTMENT_ID
<span style="color: #c678dd;">JOIN</span> HR.LOCATIONS L <span style="color: #c678dd;">ON</span> L.LOCATION_ID = D.LOCATION_ID
<span style="color: #c678dd;">JOIN</span> HR.COUNTRIES C <span style="color: #c678dd;">ON</span> L.COUNTRY_ID = C.COUNTRY_ID
<span style="color: #c678dd;">WHERE</span> C.REGION_ID = 10 <span style="color: #c678dd;">AND</span> E.SALARY <span style="color: #c678dd;">BETWEEN</span> 4000 <span style="color: #c678dd;">AND</span> 6000;`
  },
  {
    id: "03",
    titulo: "Orden Jerárquico y Seguridad",
    enunciado: "Proyectar orden jerarquico de los cargos de los empleados, mostrar el nombre del empelado y sus jefes.",
    nota: "(empleado, jefe, extraer emails de los dos - Las primeras 3 letras, luego rellenar 6 asteriscos a la izquierda)",
    archivo: "query_03.sql",
    codigo: `<span style="color: #c678dd;">SELECT</span> 
    E.FIRST_NAME || <span style="color: #98c379;">' '</span> || E.LAST_NAME <span style="color: #c678dd;">AS</span> EMPLEADO,
    <span style="color: #e5c07b;">LPAD</span>(<span style="color: #e5c07b;">SUBSTR</span>(E.EMAIL, 1, 3), 9, <span style="color: #98c379;">'*'</span>) <span style="color: #c678dd;">AS</span> EMAIL_EMPLEADO,
    M.FIRST_NAME || <span style="color: #98c379;">' '</span> || M.LAST_NAME <span style="color: #c678dd;">AS</span> JEFE,
    <span style="color: #e5c07b;">LPAD</span>(<span style="color: #e5c07b;">SUBSTR</span>(M.EMAIL, 1, 3), 9, <span style="color: #98c379;">'*'</span>) <span style="color: #c678dd;">AS</span> EMAIL_JEFE
<span style="color: #c678dd;">FROM</span> HR.EMPLOYEES E
<span style="color: #c678dd;">LEFT JOIN</span> HR.EMPLOYEES M <span style="color: #c678dd;">ON</span> E.MANAGER_ID = M.EMPLOYEE_ID
<span style="color: #c678dd;">ORDER BY</span> E.LAST_NAME;`
  },
  {
    id: "04",
    titulo: "Serie Fibonacci hasta 100",
    enunciado: "Desarrollar un bloque PL/SQL que calcule e imprima la secuencia de Fibonacci de manera iterativa, deteniéndose antes de superar el valor de 100.",
    archivo: "ejercicio_04.sql",
    codigo: `<span style="color: #5c6370;">/* AUTOR: SANTIAGO PINZÓN VÁSQUEZ
FECHA: 18/02/2026
DESCRIPCIÓN: Bloque anónimo en PL/SQL para generar la serie de Fibonacci hasta el límite de 100.
*/</span>
<span style="color: #c678dd;">DECLARE</span>
    vn_a <span style="color: #e5c07b;">NUMBER</span> := 0; 
    vn_b <span style="color: #e5c07b;">NUMBER</span> := 1;
<span style="color: #c678dd;">BEGIN</span>
    <span style="color: #c678dd;">WHILE</span> vn_a <= 100 <span style="color: #c678dd;">LOOP</span>
        <span style="color: #e5c07b;">dbms_output.put_line</span>(vn_a); 
        vn_b := vn_a + vn_b;  
        vn_a := vn_b - vn_a; 
    <span style="color: #c678dd;">END LOOP</span>;
<span style="color: #c678dd;">END</span>;
/`
  },
  {
    id: "05",
    titulo: "Mínimo Común Múltiplo (MCM)",
    enunciado: "Cálculo del menor múltiplo común entre dos números enteros mediante un proceso iterativo con PL/SQL, utilizando el operador MOD y la función GREATEST.",
    archivo: "ejercicio_05.sql",
    codigo: `<span style="color: #5c6370;">/* AUTOR: SANTIAGO PINZÓN VÁSQUEZ
FECHA: 18/02/2026
DESCRIPCIÓN: Bloque PL/SQL para encontrar el Mínimo Común Múltiplo (MCM) de dos números de forma iterativa.
*/</span>
<span style="color: #c678dd;">DECLARE</span> 
    vn_num1   <span style="color: #e5c07b;">NUMBER</span> := 12;
    vn_num2   <span style="color: #e5c07b;">NUMBER</span> := 18;
    vn_mcm    <span style="color: #e5c07b;">NUMBER</span> := <span style="color: #e5c07b;">GREATEST</span>(vn_num1, vn_num2); 
    vb_x      <span style="color: #c678dd;">BOOLEAN</span> := <span style="color: #c678dd;">TRUE</span>;
<span style="color: #c678dd;">BEGIN</span> 
    <span style="color: #c678dd;">WHILE</span> vb_x <span style="color: #c678dd;">LOOP</span>
        <span style="color: #c678dd;">IF</span> (<span style="color: #e5c07b;">MOD</span>(vn_mcm, vn_num1) = 0) <span style="color: #c678dd;">AND</span> (<span style="color: #e5c07b;">MOD</span>(vn_mcm, vn_num2) = 0) <span style="color: #c678dd;">THEN</span>
            <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'El MCM de '</span> || vn_num1 || <span style="color: #98c379;">' y '</span> || vn_num2 || <span style="color: #98c379;">' es: '</span> || vn_mcm);
            vb_x := <span style="color: #c678dd;">FALSE</span>; 
        <span style="color: #c678dd;">ELSE</span>
            vn_mcm := vn_mcm + 1;
        <span style="color: #c678dd;">END IF</span>;
    <span style="color: #c678dd;">END LOOP</span>; 
<span style="color: #c678dd;">END</span>;
/`
  },
  {
    id: "06",
    titulo: "Raíz Cuadrada Entera",
    enunciado: "Dado un número X, identificar el número entero que elevado al cuadrado sea igual a X. En caso de no existir una raíz exacta, el programa informa que no hay raíz entera.",
    archivo: "ejercicio_06.sql",
    codigo: `<span style="color: #5c6370;">/* AUTOR: SANTIAGO PINZÓN VÁSQUEZ
FECHA:18/02/2026 
DESCRIPCIÓN: Bloque PL/SQL que utiliza un ciclo FOR para encontrar la raíz cuadrada entera de un número por búsqueda exhaustiva.
*/</span>
<span style="color: #c678dd;">DECLARE</span> 
    vn_x <span style="color: #e5c07b;">NUMBER</span> := 64;
<span style="color: #c678dd;">BEGIN</span> 
    <span style="color: #c678dd;">FOR</span> i <span style="color: #c678dd;">IN</span> 1..vn_x <span style="color: #c678dd;">LOOP</span>
        <span style="color: #c678dd;">IF</span> i * i = vn_x <span style="color: #c678dd;">THEN</span>
            <span style="color: #e5c07b;">dbms_output.put_line</span>(i);
            <span style="color: #c678dd;">RETURN</span>; 
        <span style="color: #c678dd;">END IF</span>;
    <span style="color: #c678dd;">END LOOP</span>;
    <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'No hay raíz entera'</span>);
<span style="color: #c678dd;">END</span>;
/`
  },
  {
    id: "07",
    titulo: "Stored Procedure: Saludo y Lógica de Fechas",
    enunciado: "Creación de un procedimiento almacenado en PL/SQL que demuestra el uso de parámetros opcionales con valores por defecto, concatenación de cadenas y la identificación dinámica del último viernes de un mes específico.",
    archivo: "ejercicio_07.sql",
    codigo: `<span style="color: #5c6370;">/* AUTOR: SANTIAGO PINZÓN VÁSQUEZ
FECHA: 23/02/2026
DESCRIPCIÓN: Procedimiento almacenado que gestiona parámetros IN y realiza cálculos temporales avanzados con NEXT_DAY y LAST_DAY.
*/</span>
<span style="color: #c678dd;">CREATE OR REPLACE PROCEDURE</span> sp_saludar (
    param_nombre <span style="color: #c678dd;">IN</span> <span style="color: #e5c07b;">VARCHAR2</span> <span style="color: #c678dd;">DEFAULT</span> <span style="color: #98c379;">'Millos'</span>,
    param_fecha  <span style="color: #c678dd;">IN</span> <span style="color: #e5c07b;">DATE</span>     <span style="color: #c678dd;">DEFAULT</span> <span style="color: #c678dd;">SYSDATE</span>
)
<span style="color: #c678dd;">IS</span>
    vv_textoConcatenado <span style="color: #e5c07b;">VARCHAR2</span>(100);
    vd_ultimoViernes    <span style="color: #e5c07b;">DATE</span>;
<span style="color: #c678dd;">BEGIN</span>
    vv_textoConcatenado := <span style="color: #98c379;">'Hola, '</span> || param_nombre || <span style="color: #98c379;">' tu papá '</span>;
    <span style="color: #e5c07b;">dbms_output.put_line</span>(vv_textoConcatenado);
     
    vd_ultimoViernes := <span style="color: #e5c07b;">NEXT_DAY</span>(<span style="color: #e5c07b;">LAST_DAY</span>(param_fecha) - 7, <span style="color: #98c379;">'VIERNES'</span>);
    <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'El ultimo viernes es '</span> || vd_ultimoViernes);
<span style="color: #c678dd;">END</span> sp_saludar;
/

<span style="color: #5c6370;">-- Llamada al procedimiento</span>
<span style="color: #c678dd;">BEGIN</span>
    sp_saludar();
<span style="color: #c678dd;">END</span>;
/`
  },
  {
    id: "08",
    titulo: "Cursor Dinámico: Empleados por Departamento",
    enunciado: "Implementación de un bloque PL/SQL que utiliza un cursor explícito y una variable de sustitución (&) para filtrar y listar los empleados pertenecientes a un ID de departamento ingresado por consola.",
    archivo: "ejercicio_08.sql",
    codigo: `<span style="color: #5c6370;">/* AUTOR: SANTIAGO PINZÓN VÁSQUEZ
FECHA: 02/03/2026
DESCRIPCIÓN: Cursor dinámico que filtra empleados por ID de departamento usando variables de sustitución.
*/</span>
<span style="color: #c678dd;">DECLARE</span>
    v_target_dept <span style="color: #e5c07b;">NUMBER</span> := &DIGITE_ID_DEPARTAMENTO;

    <span style="color: #c678dd;">CURSOR</span> c_empleados <span style="color: #c678dd;">IS</span>
      <span style="color: #c678dd;">SELECT</span> employee_id, first_name, last_name, department_id
      <span style="color: #c678dd;">FROM</span> EMPLOYEES
      <span style="color: #c678dd;">WHERE</span> department_id = v_target_dept;

    v_emp c_empleados<span style="color: #e5c07b;">%ROWTYPE</span>;
    v_contador <span style="color: #e5c07b;">NUMBER</span> := 0;
<span style="color: #c678dd;">BEGIN</span>
    <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'--- LISTADO PARA EL DEPARTAMENTO: '</span> || v_target_dept || <span style="color: #98c379;">' ---'</span>);

    <span style="color: #c678dd;">OPEN</span> c_empleados;
    <span style="color: #c678dd;">LOOP</span>
        <span style="color: #c678dd;">FETCH</span> c_empleados <span style="color: #c678dd;">INTO</span> v_emp;
        <span style="color: #c678dd;">EXIT WHEN</span> c_empleados<span style="color: #e5c07b;">%NOTFOUND</span>;
        
        v_contador := v_contador + 1;
        <span style="color: #e5c07b;">dbms_output.put_line</span>(
            v_emp.employee_id || <span style="color: #98c379;">' - '</span> ||
            v_emp.first_name || <span style="color: #98c379;">' '</span> ||
            v_emp.last_name ||
            <span style="color: #98c379;">' (Depto: '</span> || v_emp.department_id || <span style="color: #98c379;">')'</span>
        );
    <span style="color: #c678dd;">END LOOP</span>;
    
    <span style="color: #c678dd;">IF</span> v_contador = 0 <span style="color: #c678dd;">THEN</span>
        <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'No se encontró a nadie en el ID: '</span> || v_target_dept);
    <span style="color: #c678dd;">ELSE</span>
        <span style="color: #e5c07b;">dbms_output.put_line</span>(<span style="color: #98c379;">'Total de empleados: '</span> || v_contador);
    <span style="color: #c678dd;">END IF</span>;

    <span style="color: #c678dd;">CLOSE</span> c_empleados;
<span style="color: #c678dd;">END</span>;
/`
  }
];
---

<!DOCTYPE html>
<html lang="es">
  <Header title="Actividades | Santiago" />
  <body>
    <div class="content">
      <Sidebar selectedItem="actividades" />
      <nav class="main">
        <div class="container" style="max-width: 1200px; padding: 60px 40px;">
          
          <header style="margin-bottom: 80px; border-bottom: 1px solid #222; padding-bottom: 30px;">
            <h2 style="font-size: 3.5rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 20px;">
              Actividades Oracle SQL
            </h2>
            <div style="background: #1a1a1a; border-left: 4px solid #ffbd2e; padding: 15px 25px; border-radius: 4px;">
              <p style="color: #e0e0e0; font-size: 1.1rem; line-height: 1.6; margin: 0;">
                Ejercicios desarrollados durante la asignatura de <strong>Bases de Datos II</strong>. Esta sección incluye retos de lógica, consultas complejas y aplicaciones prácticas.
              </p>
            </div>
          </header>

          <div id="exercises-container" class="activities-stack" style="display: flex; flex-direction: column; gap: 90px;">
            {ejercicios.map((ej) => (
              <section class="activity-item">
                <div style="margin-bottom: 35px;"> 
                  <span style="color: #fff; background: #333; padding: 5px 15px; border-radius: 4px; font-family: monospace; font-size: 0.8rem;">EJERCICIO {ej.id}</span>
                  <h3 style="font-size: 2.2rem; margin: 20px 0; color: #fff;">{ej.titulo}</h3>
                  <p style="color: #bbb; font-size: 1.2rem; line-height: 1.8; margin-top: 15px;"> 
                    {ej.enunciado}
                    {ej.nota && <><br/><span style="color: #777; font-size: 1rem;">{ej.nota}</span></>}
                  </p>
                </div>

                <div class="code-terminal" style="width: 100%; background: #0d0d0d; border-radius: 12px; border: 1px solid #222; overflow: hidden; box-shadow: 0 30px 60px rgba(0,0,0,0.5);">
                  <div style="background: #1a1a1a; padding: 12px 20px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #222;">
                    <div style="display: flex; gap: 8px;">
                      <div style="width: 12px; height: 12px; border-radius: 50%; background: #ff5f56;"></div>
                      <div style="width: 12px; height: 12px; border-radius: 50%; background: #ffbd2e;"></div>
                      <div style="width: 12px; height: 12px; border-radius: 50%; background: #27c93f;"></div>
                    </div>
                    <span style="color: #555; font-family: monospace; font-size: 0.8rem;">{ej.archivo}</span>
                  </div>
                  <pre style="margin: 0; padding: 40px; overflow-x: auto; font-family: 'Fira Code', monospace; font-size: 1.1rem; line-height: 1.6;"><code style="color: #abb2bf;" set:html={ej.codigo}></code></pre>
                </div>
              </section>
            ))}
          </div>

          <div id="pagination-controls" style="margin-top: 80px; display: flex; justify-content: center; gap: 15px;">
            </div>

        </div>
      </nav>
    </div>

    <style>
      .page-btn {
        background: #1a1a1a;
        color: #888;
        border: 1px solid #333;
        padding: 10px 20px;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.3s ease;
      }
      .page-btn:hover {
        border-color: #ffbd2e;
        color: #fff;
      }
      .page-btn.active {
        background: #ffbd2e;
        color: #000;
        border-color: #ffbd2e;
      }
    </style>

    <script>
      const ITEMS_PER_PAGE = 5;
      const container = document.getElementById('exercises-container');
      const exercises = Array.from(container.getElementsByClassName('activity-item'));
      const paginationControls = document.getElementById('pagination-controls');
      
      const totalPages = Math.ceil(exercises.length / ITEMS_PER_PAGE);

      function showPage(pageNumber) {
        const start = (pageNumber - 1) * ITEMS_PER_PAGE;
        const end = start + ITEMS_PER_PAGE;

        exercises.forEach((ex, index) => {
          ex.style.display = (index >= start && index < end) ? 'block' : 'none';
        });

        // Actualizar botones
        document.querySelectorAll('.page-btn').forEach(btn => {
          btn.classList.toggle('active', parseInt(btn.innerText) === pageNumber);
        });

        // Scroll suave arriba
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      // Generar botones
      for (let i = 1; i <= totalPages; i++) {
        const btn = document.createElement('button');
        btn.innerText = i;
        btn.className = 'page-btn';
        btn.onclick = () => showPage(i);
        paginationControls.appendChild(btn);
      }

      // Mostrar la primera página al cargar
      showPage(1);
    </script>

  </body>
</html>